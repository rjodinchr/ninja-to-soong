cc_genrule {
    name: "libclc_CMakeFiles_clc_builtins_clspv___dir_clc_lib_clspv_math_clc_sw_fma_cl_o",
    cmd: "$(location) -x cl -c -flto --target=spir-- -nostdlib -nostdlibinc -cl-no-stdinc -cl-std=CL3.0 -include $(location :ClangHeaders_lib_Headers_opencl-c-base_h) -Werror=undef -Wall -Wextra -fdiscard-value-names -ffp-contract=fast-honor-pragmas -fdenormal-fp-math=dynamic -Wno-unknown-assumption -DCLC_CLSPV -DCLC_CLSPV32 -D__CLC_GENERIC_ADDRSPACE_VAL=0 -D__CLC_PRIVATE_ADDRSPACE_VAL=0 -I$$(dirname $(location CMakeLists.txt))/clc/include -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/async -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/atomic -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/collective -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/common -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/conversion -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/geometric -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/integer -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/math -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/mem_fence -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/misc -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/relational -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/shared -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/subgroup -I$$(dirname $(location CMakeLists.txt))/clc/lib/generic/workitem -I$$(dirname $(location CMakeLists.txt))/clc/lib/clspv/integer -I$$(dirname $(location clc/lib/clspv/math/clc_sw_fma.cl))  -o $(location CMakeFiles/clc_builtins_clspv__.dir/clc/lib/clspv/math/clc_sw_fma.cl.o) $(location clc/lib/clspv/math/clc_sw_fma.cl)",
    srcs: ["clc/lib/clspv/math/clc_sw_fma.cl"],
    out: ["CMakeFiles/clc_builtins_clspv__.dir/clc/lib/clspv/math/clc_sw_fma.cl.o"],
    tools: ["llvm-project_bin_clang-23"],
    defaults: ["libclc-defaults"],
}

